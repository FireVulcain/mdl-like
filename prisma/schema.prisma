generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String           @id @default(cuid())
  name          String?
  email         String?          @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  media         UserMedia[]
  activityLogs  ActivityLog[]
  podiums       ProfilePodium[]
  preferences   UserPreferences?
  recFeedback   RecommendationFeedback[]
  radarExclusions ActorRadarExclusion[]
  radarPins     ActorRadarPin[]
  lastSeenSync  DateTime?
}

// Actors the user manually added to the "From Actors You Watch" radar —
// always scanned, regardless of computed affinity.
model ActorRadarPin {
  id           String   @id @default(cuid())
  userId       String
  personSlug   String // bare kuryana person slug
  name         String
  profileImage String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, personSlug])
  @@index([userId])
}

// Actors the user has removed from the "From Actors You Watch" radar.
// Kept as rows (not a Json blob) so they can be listed and restored.
model ActorRadarExclusion {
  id           String   @id @default(cuid())
  userId       String
  personSlug   String // bare kuryana person slug, e.g. "22074-go-yoon-jung"
  name         String
  profileImage String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, personSlug])
  @@index([userId])
}

// "Not interested" dismissals from the recommendation dialog. Keyed by show+season
// (not UserMedia id) so the signal survives watchlist row deletion/re-creation.
model RecommendationFeedback {
  id         String   @id @default(cuid())
  userId     String
  externalId String
  season     Int      @default(1)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, externalId, season])
  @@index([userId])
}

model UserPreferences {
  userId                     String  @id
  calendarAsianOnly          Boolean @default(false)
  calendarIncludePlanToWatch Boolean @default(true)
  // MDL tags excluded from the home top lists: [{ id, name }].
  // null = app defaults, [] = user explicitly cleared all exclusions.
  homeExcludedTags           Json?
  user                       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserMedia {
  id            String    @id @default(cuid())
  userId        String
  externalId    String
  source        String
  mediaType     String
  status        String
  progress      Int
  totalEp       Int?
  score         Float?
  title         String?
  poster        String?
  year          Int?
  originCountry String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  notes         String?
  season        Int       @default(1)
  tmdbRating    Float?
  genres        String?
  backdrop      String?
  mdlRating     Float?
  airingStatus  String?
  lastWatchedAt DateTime?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProfilePodium {
  id         String  @id @default(cuid())
  userId     String
  category   String // "general" | "kdrama" | "cdrama"
  rank       Int // 1, 2, 3
  externalId String
  source     String
  mediaType  String
  title      String
  poster     String?
  year       Int?
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, rank])
  @@index([userId, category])
}

model SyncLog {
  id       String   @id @default("daily-sync")
  lastSync DateTime @default(now())
  results  Json?
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  userMediaId String?
  externalId  String
  source      String
  mediaType   String
  title       String
  poster      String?
  action      String
  payload     Json?
  createdAt   DateTime @default(now())
  isBackfill  Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userMediaId])
}

model CachedMdlData {
  id             String   @id @default(cuid())
  tmdbExternalId String   @unique
  mdlSlug        String
  mdlDisabled    Boolean  @default(false)
  mdlRating      Float?
  mdlRanking     Int?
  mdlPopularity  Int?
  tags           Json?
  genres         Json?
  castJson       Json?
  directors      Json?
  screenwriters  Json?
  synopsis       String?
  cachedAt       DateTime @default(now())
}

model CachedKuryanaPerson {
  slug     String   @id
  dataJson Json
  cachedAt DateTime @default(now())
}

model MdlSeasonLink {
  id             String    @id @default(cuid())
  tmdbExternalId String
  season         Int
  mdlSlug        String
  mdlRating      Float?
  mdlRanking     Int?
  mdlPopularity  Int?
  castJson       Json?
  tags           Json?
  genres         Json?
  synopsis       String?
  cachedAt       DateTime?

  @@unique([tmdbExternalId, season])
  @@index([tmdbExternalId])
}

model MdlAlias {
  id             String   @id @default(cuid())
  mdlSlug        String   @unique // the alias MDL slug (e.g. "the-glory-part-2")
  tmdbExternalId String // points to the main CachedMdlData entry
  createdAt      DateTime @default(now())

  @@index([tmdbExternalId])
}

model CachedMdlEpisode {
  id            String   @id @default(cuid())
  mdlSlug       String
  episodeNumber Int
  synopsis      String?
  episodeTitle  String?
  cachedAt      DateTime @default(now())

  @@unique([mdlSlug, episodeNumber])
  @@index([mdlSlug])
}

model CachedEpisode {
  id            String   @id @default(cuid())
  mediaId       String
  airDate       String
  episodeNumber Int
  seasonNumber  Int
  episodeName   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  @@unique([mediaId, seasonNumber, episodeNumber])
  @@index([mediaId])
}
